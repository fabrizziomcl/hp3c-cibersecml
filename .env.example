# Environment Configurations
APP_ENV=development
PORT=8000

# Data paths
DATASET_PATH=dataset/Obfuscated-MalMem2022.csv
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
EXTERNAL_DATA_DIR=data/external

# Model artifacts
MODEL_PATH=models/model.pkl
PREPROCESSOR_PATH=models/preprocessor.pkl

# Reports & logs
REPORTS_DIR=reports
LOGS_DIR=logs
LOG_LEVEL=INFO

# Training hyperparameters
RF_N_ESTIMATORS=100
RF_MAX_DEPTH=12
TEST_SIZE=0.2
SIMULATION_SPLIT_SIZE=0.2
RANDOM_STATE=42

# HPC / parallelism
N_JOBS=-1
HPC_NUM_WORKERS=4
PCA_COMPONENTS=3

# Reentrenamiento: forzar desbalance solo en experimentación
FORCE_IMBALANCE=false
